{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Greenroom-Robotics/ros_semantic_release_action/main/dispatch-payload.schema.json",
  "title": "package-released dispatch payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["package", "version", "source_repo", "sha"],
  "properties": {
    "package": {
      "type": "string",
      "description": "Package name as it appears in the recipes repo: bare ROS name, or conda name (hyphens allowed) for vendored recipes.",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "version": {
      "type": "string",
      "description": "Semver string, no leading v.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$"
    },
    "source_repo": {
      "type": "string",
      "description": "GitHub <owner>/<repo> the release came from.",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "sha": {
      "type": "string",
      "description": "SHA of the tagged commit.",
      "pattern": "^[0-9a-f]{40}$"
    },
    "manifest_type": {
      "type": "string",
      "description": "Manifest format the source repo uses. Defaults to pixi.toml when omitted.",
      "enum": ["pixi.toml", "package.xml"]
    },
    "subdir": {
      "type": "string",
      "description": "Path from source-repo root to the package's manifest dir. Omitted when the package sits at the repo root."
    }
  }
}
